                    <img src="~/Content/images/sunglass.jpg" alt="shoes" height=160>
                    <div class="product">Ray-Ban</div>
                    <div class="price">₹4,000</div>

                </div>
                <div class="msection">

                    <img src="~/Content/images/boytshirt.jpg" alt="tshirt" height=160>
                    <div class="product">ZUDIO</div>
                    <div class="price">₹4,000</div>

                </div>
                <div class="msection">

                    <img src="~/Content/images/ps5.jpg" alt="ps5" height=160>
                    <div class="product">PS5</div>
                    <div class="price">₹4,000</div>

                </div>
                <div class="msection">

                    <img src="~/Content/images/boywallet.jpg" alt="boywallet" height=160>
                    <div class="product">PS5</div>
                    <div class="price">₹4,000</div>

                </div>
                <div class="msection">

                    <img src="~/Content/images/ps5.jpg" alt="ps5" height=160>
                    <div class="product">PS5</div>
                    <div class="price">₹4,000</div>

                </div>
                <div class="msection">
                    <img src="~/Content/images/watch.jpg" alt="ps5" height=160>
                    <div class="product">PS5</div>
                    <div class="price">₹4,000</div>

                </div>

            </div>

        </div>
   
</body>
</html>