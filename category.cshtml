        <div class="hom">
            🛒Welcome to e-com</a>
            <p> Best deals, best prices — all in one place!</p>
            <button> <a href="/Login_page/Index" style="text-decoration:none;">Go Home </a> </button>
        </div>

    </div>
    <div class="selectc">Select Category</div>
    
    <div class="product">
        <div class="mwk">
