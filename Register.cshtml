@model ecom.Login_Page

@{
    ViewBag.Title = "Register";
}
<style>
    body {
        background-image: url("/Content/images/register.jpg");
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        height: 100%;
        margin: 0;
    }
    .register {
        background-color: rgba(255, 255, 255, 0.15);
        border: 2px solid rgba(255, 255, 255, 0.4);
        border-radius: 16px;
        padding: 42px 35px;
        width: 500px;
        height:70%;
        backdrop-filter: blur(10px);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        position: relative;
        left: 650px;
        top: 1px;
    }
    label {
        color: black;
        font-size: 18px;
        margin-bottom: 6px;
        display:inline;
    }
    .intake {
        width: 100%;
        height:70%;
        padding: 12px 16px;
        border: 1px solid rgba(255,255,255,0.4);
        border-radius: 8px;
        background: rgba(255,255,255,0.2);
        color: black;
        font-size: 15px;
        margin-bottom: 20px;
        outline: none;
        transition: border 0.3s;
    }
    .form-row {
        display: flex;
        align-items: center;
        margin-bottom: 1px;
    }

    .form-row label {
     width: 150px; /* label ki fixed width */
     font-weight: bold;
    }
        .form-row .intake input,
        .form-row .intake textarea {
            width: 250px;
        }

    .intake input,
    .intake textarea {
        border: none; /* border hata diya */
        outline: none; /* click pe blue outline hata diya */
        box-shadow: none; /* shadow hata diya */
        background-color: transparent;
    }
    button {
        width: 100%;
        padding: 13px;
        background-color: #7c3aed;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 16px;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.2s;
        letter-spacing: 1px;
        position:relative;
        bottom:15px;
        
        
    }
    


</style>

@*<h2>User Registration</h2>*@

@using (Html.BeginForm("Register", "Login_Page", FormMethod.Post))
{
    @Html.AntiForgeryToken()
 <div class="register">
    <div class="form-row">
        <label>Username</label>
        <div class="intake">
            @Html.TextBoxFor(m => m.user_name)
        </div>
    </div>
    <br />

    <div class="form-row">
        <label>Email</label>
        <div class="intake">
            @Html.TextBoxFor(m => m.email)
         </div>
    </div>
            <br />

            <div class="form-row">
                <label>Mobile Number</label>
                <div class="intake">
                    @Html.TextBoxFor(m => m.mobile_number)
                </div>
            </div>
            <br />

            <div class="form-row">
                <label>Address</label>
                <div class="intake">
                    @Html.TextAreaFor(m => m.address)
                </div>
            </div>
            <br />

            <div class="form-row">
                <label>Password</label>
                <div class="intake">
                    @Html.PasswordFor(m => m.user_password)
                </div>
            </div>
            <br />

            <div class="form-row">
                <label>Confirm Password</label>
                <div class="intake">
                    <input type="password" name="confirm_password" />
                </div>
            </div>
            <br />
            <div class="but">
                <button type="submit">Register</button>
            </div>
  </div>
}